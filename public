<script>
// ⚙️ Cambiá esta URL por la de tu proyecto en Vercel tras el deploy
const PROXY_URL = 'https://arhome-proxy.vercel.app';

let uploadedFiles  = [];   // array de {file, base64}
let loadingTimer   = null;

// ─────────────────────────────────────────────
// All DOM-touching code runs after full parse
// ─────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {

  // ── API KEY ──────────────────────────────────


  // ── UPLOAD (múltiples fotos) ──────────────────
  const uploadZone = document.getElementById('upload-zone');
  uploadZone.addEventListener('dragover',  function(e){ e.preventDefault(); uploadZone.classList.add('drag-over'); });
  uploadZone.addEventListener('dragleave', function(){ uploadZone.classList.remove('drag-over'); });
  uploadZone.addEventListener('drop', function(e) {
    e.preventDefault();
    uploadZone.classList.remove('drag-over');
    processFiles(e.dataTransfer.files);
  });

  window.handleFileSelect = function(e) {
    if (e.target.files && e.target.files.length) processFiles(e.target.files);
  };

  window.removeImage = function(idx) {
    uploadedFiles.splice(idx, 1);
    renderPreviews();
    checkReady();
  };

  // Comprimir imagen a max 800px y 80% calidad antes de enviar
  function compressImage(dataUrl, mime, callback) {
    var img = new Image();
    img.onload = function() {
      var MAX = 800;
      var scale = Math.min(1, MAX / Math.max(img.width, img.height));
      var canvas = document.createElement('canvas');
      canvas.width  = Math.round(img.width  * scale);
      canvas.height = Math.round(img.height * scale);
      canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
      var compressed = canvas.toDataURL('image/jpeg', 0.80);
      callback(compressed.split(',')[1], 'image/jpeg', compressed);
    };
    img.src = dataUrl;
  }

  function processFiles(fileList) {
    var allowed = Array.from(fileList).filter(function(f){ return f.type.startsWith('image/'); });
    var remaining = 5 - uploadedFiles.length;
    if (remaining <= 0) { showError('Ya subiste el máximo de 5 fotos.'); return; }
    allowed = allowed.slice(0, remaining);
    var pending = allowed.length;
    if (!pending) return;
    allowed.forEach(function(file) {
      if (file.size > 10 * 1024 * 1024) { showError('Una imagen supera los 10MB.'); pending--; return; }
      var reader = new FileReader();
      reader.onload = function(ev) {
        compressImage(ev.target.result, file.type, function(b64, mime, dataUrl) {
          uploadedFiles.push({ file: file, base64: b64, mime: mime, dataUrl: dataUrl });
          pending--;
          if (pending === 0) { renderPreviews(); checkReady(); }
        });
      };
      reader.readAsDataURL(file);
    });
    // reset input para permitir subir los mismos archivos de nuevo
    document.getElementById('file-input').value = '';
  }

  function renderPreviews() {
    var grid = document.getElementById('photos-grid');
    var container = document.getElementById('preview-container');
    if (!uploadedFiles.length) {
      container.style.display = 'none';
      grid.innerHTML = '';
      return;
    }
    container.style.display = 'block';
    grid.innerHTML = uploadedFiles.map(function(item, i) {
      return '<div class="photo-thumb">'
        + '<img src="' + item.dataUrl + '" alt="Foto ' + (i+1) + '">'
        + '<button class="remove-btn" onclick="removeImage(' + i + ')">✕</button>'
        + '</div>';
    }).join('');
  }


  // ── CATÁLOGO DINÁMICO ─────────────────────────
  // IDs de categorías de Tienda Nube (arhomedesigns)
  // Categorías con IDs verificados del resultado real de la API
  const CATEGORIAS = [
    { key:'marmol',   label:'Placas Símil Mármol',  catIds:[24858495],                            tipo:'pared' },
    { key:'metal',    label:'Placas Símil Metal',    catIds:[26295912],                            tipo:'pared' },
    { key:'texturas', label:'Placas Símil Texturas', catIds:[25342641],                            tipo:'pared' },
    { key:'espejo',   label:'Placas Espejo',         catIds:[29761945],                            tipo:'pared' },
    { key:'laminas',  label:'Láminas de Piedra',     catIds:[27092822],                            tipo:'pared' },
    { key:'wall',     label:'Wall Panels',           catIds:[24138050,34124000],                   tipo:'pared' },
    { key:'jardines', label:'Jardines Verticales',   catIds:[24210122],                            tipo:'pared' },
    { key:'macizos',  label:'Pisos Madera',          catIds:[25341096,25400350,25400351],          tipo:'piso'  },
    { key:'flotante', label:'Pisos Flotantes',       catIds:[25341097,25453142,25453143],          tipo:'piso'  },
    { key:'vinilico', label:'Pisos Vinílicos',       catIds:[25341098],                            tipo:'piso'  },
    { key:'rollo',    label:'Pisos en Rollo',        catIds:[25341095],                            tipo:'piso'  },
  ];

  let PRODUCTS     = {};   // { key: [{name, img}] }
  let selectedProduct  = null;
  let currentCatKey    = null;
  let catalogLoaded    = false;

  async function loadCatalog() {
    var grid = document.getElementById('prod-grid');
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#aaa;padding:2rem;font-size:0.85rem;">Cargando productos...</div>';

    try {
      var allProds = [];
      for (var page = 1; page <= 6; page++) {
        var url = PROXY_URL + '/api/products?page=' + page;
        var r = await fetch(url);
        if (!r.ok) break;
        var data = await r.json();
        if (!data || !data.length || data.error) break;
        // Solo productos publicados (visibles en la tienda)
        var pubProds = data.filter(function(p) { return p.published === true; });
        allProds = allProds.concat(pubProds);
        if (data.length < 50) break; // última página
      }

      if (!allProds.length) {
        grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#F09595;padding:2rem;">Sin productos disponibles.</div>';
        return;
      }

      // Inicializar categorías
      CATEGORIAS.forEach(function(cat) { PRODUCTS[cat.key] = []; });

      allProds.forEach(function(prod) {
        if (!prod.images || !prod.images.length) return;
        var img  = prod.images[0].src;
        var name = prod.name && prod.name.es ? prod.name.es : (typeof prod.name === 'string' ? prod.name : '');
        if (!name || !img) return;
        var catIds = (prod.categories || []).map(function(c){ return parseInt(c.id); });

        CATEGORIAS.forEach(function(cat) {
          var match = cat.catIds.some(function(id){ return catIds.includes(id); });
          if (match && !PRODUCTS[cat.key].find(function(p){ return p.name === name; })) {
            PRODUCTS[cat.key].push({ name: name, img: img, tipo: cat.tipo });
          }
        });
      });

      catalogLoaded = true;
      initProductSelector();

    } catch(err) {
      console.error('Error cargando catálogo:', err);
      grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#F09595;padding:2rem;">Error al cargar productos. Verificá tu conexión.</div>';
    }
  }


  function initProductSelector() {
    var cats = CATEGORIAS.filter(function(c){ return PRODUCTS[c.key] && PRODUCTS[c.key].length > 0; });
    var btnHtml = '';
    cats.forEach(function(cat) {
      btnHtml += '<button class="prod-cat-btn" data-cat="' + cat.key + '" data-tipo="' + cat.tipo + '">' + cat.label + ' (' + PRODUCTS[cat.key].length + ')' + '</button>';
    });
    document.getElementById('prod-cats').innerHTML = btnHtml;
    document.querySelectorAll('.prod-cat-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.prod-cat-btn').forEach(function(b){ b.classList.remove('active'); });
        btn.classList.add('active');
        currentCatKey = btn.dataset.cat;
        renderProductGrid(btn.dataset.cat);
      });
    });
    if (cats.length > 0) {
      document.querySelector('.prod-cat-btn').classList.add('active');
      currentCatKey = cats[0].key;
      renderProductGrid(cats[0].key);
    }
  }

  function renderProductGrid(catKey) {
    var prods = PRODUCTS[catKey] || [];
    var grid  = document.getElementById('prod-grid');
    if (!prods.length) {
      grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#aaa;padding:2rem;">Sin productos en esta categoría.</div>';
      return;
    }
    var html = '';
    prods.forEach(function(p) {
      var isSel = selectedProduct && selectedProduct.name === p.name;
      html += '<div class="prod-card' + (isSel ? ' selected' : '') + '" data-pname="' + p.name.replace(/"/g,'&quot;') + '" data-pimg="' + p.img.replace(/"/g,'&quot;') + '" data-ptipo="' + (p.tipo||'pared') + '">'
            + '<img src="' + p.img + '" alt="' + p.name.replace(/"/g,'') + '" loading="lazy">'
            + '<div class="prod-card-name">' + p.name + '</div>'
            + '</div>';
    });
    grid.innerHTML = html;

    document.querySelectorAll('.prod-card').forEach(function(card) {
      card.addEventListener('click', function() {
        var prod = {
          name: card.getAttribute('data-pname'),
          img:  card.getAttribute('data-pimg'),
          tipo: card.getAttribute('data-ptipo')
        };
        selectProduct(prod);
        document.querySelectorAll('.prod-card').forEach(function(c){ c.classList.remove('selected'); });
        card.classList.add('selected');
      });
    });
  }


  function selectProduct(prod) {
    selectedProduct = prod;
    var info = document.getElementById('prod-selected-info');
    info.style.display = 'flex';
    info.innerHTML = '<img src="' + prod.img + '" alt="' + prod.name + '">'
                   + '<span><strong style="color:var(--gold);">Seleccionado:</strong> ' + prod.name + '</span>';
    handleCategoryChange();
    checkReady();
  }

  // ── CATEGORY LOGIC ────────────────────────────
  function getCategoryType() {
    if (!selectedProduct) return null;
    // Usar tipo embebido en el producto (cargado dinámicamente)
    if (selectedProduct.tipo === 'piso') return 'piso';
    if (selectedProduct.tipo === 'pared') return 'pared';
    // Fallback por nombre
    var name = selectedProduct.name.toLowerCase();
    if (name.includes('piso') || name.includes('flotante') || name.includes('bamboo') || name.includes('maciza') || name.includes('waterproof') || name.includes('melaminico') || name.includes('roble') || name.includes('lapacho') || name.includes('merbau') || name.includes('vinilico')) return 'piso';
    return 'pared';
  }

  function getCategoryLabel() {
    return selectedProduct ? selectedProduct.name : '';
  }

  function handleCategoryChange() {
    const type = getCategoryType();
    const fp   = document.getElementById('fields-piso');
    const fw   = document.getElementById('fields-pared');
    fp.style.display = (type === 'piso')  ? 'block' : 'none';
    fw.style.display = (type === 'pared') ? 'block' : 'none';
    if (type !== 'pared') {
      document.getElementById('walls-count').value          = '';
      document.getElementById('walls-container').style.display = 'none';
      document.getElementById('walls-grid').innerHTML        = '';
    }
    checkReady();
  }

  // product selection now handled by visual grid
  document.getElementById('lead-name').addEventListener('input', checkReady);
  document.getElementById('lead-whatsapp').addEventListener('input', checkReady);

  // ── WALLS ─────────────────────────────────────
  window.renderWallInputs = function() {
    const n         = parseInt(document.getElementById('walls-count').value) || 0;
    const container = document.getElementById('walls-container');
    const grid      = document.getElementById('walls-grid');
    if (!n) { container.style.display = 'none'; grid.innerHTML = ''; return; }
    container.style.display = 'block';
    let html = '';
    for (let i = 1; i <= n; i++) {
      html += '<div class="field-group"><label>Pared ' + i + ' — Ancho (m)</label>'
            + '<input type="text" id="wall-' + i + '-w" placeholder="Ej: 3.5"></div>';
      html += '<div class="field-group"><label>Pared ' + i + ' — Alto (m)</label>'
            + '<input type="text" id="wall-' + i + '-h" placeholder="Ej: 2.6"></div>';
    }
    grid.innerHTML = html;
  };

  function getMeasuresInfo() {
    const type = getCategoryType();
    if (type === 'piso') {
      const m2 = document.getElementById('floor-m2').value.trim();
      return m2 ? 'SUPERFICIE: ' + m2 + ' m²' : '';
    }
    if (type === 'pared') {
      const n = parseInt(document.getElementById('walls-count').value) || 0;
      const lines = [];
      if (n) lines.push('PAREDES A RENOVAR: ' + n);
      for (let i = 1; i <= n; i++) {
        const pw = (document.getElementById('wall-' + i + '-w') || {}).value || '—';
        const ph = (document.getElementById('wall-' + i + '-h') || {}).value || '—';
        lines.push('Pared ' + i + ': ' + pw.trim() + 'm ancho x ' + ph.trim() + 'm alto');
      }
      return lines.join('\n');
    }
    return '';
  }

  // ── CHECK READY ───────────────────────────────
  function checkReady() {
    var name = document.getElementById('lead-name').value.trim();
    var wa   = document.getElementById('lead-whatsapp').value.trim();
    document.getElementById('generate-btn').disabled = !(uploadedFiles.length && name && wa && selectedProduct);
  }

  // ── TELEGRAM ──────────────────────────────────
  function b64toBlob(b64, type) {
    const bin = atob(b64);
    const arr = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
    return new Blob([arr], { type: type });
  }

  async function sendToTelegram(msgText, imgBase64, imgType) {
    const base = PROXY_URL + '/api/telegram';
    try {
      await fetch(base, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'message', text: msgText })
      });
    } catch(e) { console.warn('TG msg error', e); }
    if (imgBase64) {
      try {
        await fetch(base, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'photo', photo: imgBase64, caption: '📷 Foto original del cliente' })
        });
      } catch(e) { console.warn('TG photo error', e); }
    }
  }

  // ── GENERATE ──────────────────────────────────
  window.generateRender = async function() {
    if (!uploadedFiles.length) { showError('Primero subí al menos una foto de tu ambiente.'); return; }

    var leadName = document.getElementById('lead-name').value.trim();
    var leadWA   = document.getElementById('lead-whatsapp').value.trim();
    var category = getCategoryLabel();
    var room     = document.getElementById('room-type').value;
    var measures = getMeasuresInfo();

    if (!leadName) { showError('Por favor ingresá tu nombre completo.');   document.getElementById('lead-name').focus();     return; }
    if (!leadWA)   { showError('Por favor ingresá tu número de WhatsApp.'); document.getElementById('lead-whatsapp').focus(); return; }

    hideError();
    showLoading();

    try {
      var now = new Date().toLocaleString('es-AR', { timeZone: 'America/Argentina/Buenos_Aires' });

      // Mensaje Telegram
      var tg = '🏠 <b>Nueva consulta — AR Home Designs</b>\n\n';
      tg += '👤 <b>Cliente:</b> ' + leadName + '\n';
      tg += '📱 <b>WhatsApp:</b> ' + leadWA + '\n\n';
      tg += '🛒 <b>Producto:</b> ' + (category || 'No especificado') + '\n';
      tg += '🏡 <b>Ambiente:</b> ' + (room || 'No especificado') + '\n';
      if (measures) {
        measures.split('\\n').forEach(function(l){ if (l) tg += '  ' + l + '\\n'; });
      }
      tg += '\n📷 <b>Fotos adjuntas:</b> ' + uploadedFiles.length + '\n';
      tg += '🕐 ' + now;

      // Enviar texto
      await fetch(PROXY_URL + '/api/telegram', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'message', text: tg })
      });

      // Enviar cada foto
      for (var i = 0; i < uploadedFiles.length; i++) {
        var item = uploadedFiles[i];
        await fetch(PROXY_URL + '/api/telegram', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type:    'photo',
            photo:   item.base64,
            caption: 'Foto ' + (i + 1) + ' de ' + uploadedFiles.length + ' — ' + leadName
          })
        });
      }

      hideLoading();
      showResult(leadName, category, room);

    } catch(err) {
      hideLoading();
      console.error('Error:', err);
      showError('Error al enviar: ' + err.message);
    }
  };

  // ── SHOW RESULT ───────────────────────────────
  function showResult(leadName, category, room) {
    var rs = document.getElementById('result-section');
    rs.style.display = 'block';
    rs.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── DOWNLOAD ──────────────────────────────────
  window.downloadRender = function() {
    const src = window._lastRenderedImg || document.getElementById('render-img').src || document.getElementById('before-img').src;
    const a   = document.createElement('a');
    a.href    = src;
    a.download = 'arhome-render.jpg';
    a.click();
  };

  // ── UI HELPERS ────────────────────────────────
  function showLoading() {
    document.getElementById('loading-overlay').classList.add('active');
    const steps = ['step1','step2','step3','step4'];
    let i = 0;
    steps.forEach(function(s){ document.getElementById(s).className = 'loading-step'; });
    loadingTimer = setInterval(function() {
      if (i > 0) document.getElementById(steps[i-1]).className = 'loading-step done';
      if (i < steps.length) { document.getElementById(steps[i]).className = 'loading-step active'; i++; }
      else clearInterval(loadingTimer);
    }, 1400);
  }

  function hideLoading() {
    clearInterval(loadingTimer);
    document.getElementById('loading-overlay').classList.remove('active');
  }

  function showError(msg) {
    const el = document.getElementById('error-msg');
    el.textContent = msg;
    el.classList.add('show');
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function hideError() {
    document.getElementById('error-msg').classList.remove('show');
  }

  // Initialize product selector after all functions are defined
  loadCatalog();

}); // end DOMContentLoaded

// Comunicar altura al iframe padre (Tienda Nube)
function notifyHeight() {
  var h = document.body.scrollHeight;
  if (window.parent !== window) {
    window.parent.postMessage({ iframeHeight: h }, '*');
  }
}
window.addEventListener('load', notifyHeight);
window.addEventListener('resize', notifyHeight);
var _heightObserver = new MutationObserver(notifyHeight);
_heightObserver.observe(document.body, { childList: true, subtree: true, attributes: true });
</script>

