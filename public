<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Visualizá tu Ambiente | AR Home Designs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold: #2E86AB;
    --gold-light: #7BBDD4;
    --gold-dark: #1A5F7A;
    --charcoal: #0F1923;
    --stone: #162230;
    --warm-white: #EEF4F8;
    --muted: #7A95A8;
    --border: rgba(46,134,171,0.28);
    --font-display: 'Cormorant Garamond', serif;
    --font-body: 'DM Sans', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--charcoal);
    color: var(--warm-white);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.5rem 3rem;
    background: #000000;
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--gold);
    text-decoration: none;
  }
  .nav-logo span { color: var(--warm-white); font-weight: 300; }
  .nav-link {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--gold); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center;
    padding: 8rem 3rem 5rem;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 70% 50%, rgba(46,134,171,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-grid {
    position: absolute; inset: 0; opacity: 0.04;
    background-image: linear-gradient(var(--gold) 1px, transparent 1px),
                      linear-gradient(90deg, var(--gold) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .hero-content { position: relative; max-width: 620px; }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 2rem;
  }
  .hero-eyebrow::before {
    content: ''; display: block; width: 32px; height: 1px; background: var(--gold);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .hero-title em { font-style: italic; color: var(--gold); font-weight: 400; }
  .hero-sub {
    font-size: 1rem;
    color: rgba(247,244,239,0.65);
    margin-bottom: 3rem;
    max-width: 480px;
    line-height: 1.8;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.5rem;
    background: var(--gold);
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: none; cursor: pointer;
    text-decoration: none;
    transition: background 0.25s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); }
  .btn-outline {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 1rem 2.5rem;
    background: transparent;
    color: var(--warm-white);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.25s, color 0.25s;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ─── HOW IT WORKS ─── */
  .section { padding: 7rem 3rem; }
  .section-label {
    font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.75rem;
  }
  .section-label::before { content: ''; width: 24px; height: 1px; background: var(--gold); }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-sub { color: rgba(247,244,239,0.6); max-width: 520px; font-size: 0.95rem; line-height: 1.8; }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1px;
    margin-top: 4rem;
    border: 1px solid var(--border);
  }
  .step {
    padding: 2.5rem 2rem;
    border-right: 1px solid var(--border);
    position: relative;
    transition: background 0.25s;
  }
  .step:last-child { border-right: none; }
  .step:hover { background: rgba(46,134,171,0.05); }
  .step-num {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 300;
    color: rgba(201,169,110,0.2);
    line-height: 1;
    margin-bottom: 1.5rem;
  }
  .step-icon {
    width: 40px; height: 40px;
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--gold);
    font-size: 1.2rem;
  }
  .step h3 {
    font-family: var(--font-display);
    font-size: 1.2rem; font-weight: 400;
    margin-bottom: 0.75rem;
    color: var(--warm-white);
  }
  .step p { font-size: 0.875rem; color: var(--muted); line-height: 1.75; }

  /* ─── TOOL SECTION ─── */
  .tool-section {
    padding: 6rem 3rem;
    background: var(--stone);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .tool-wrapper {
    max-width: 960px;
    margin: 0 auto;
  }
  .tool-header { text-align: center; margin-bottom: 3.5rem; }

  /* Upload Zone */
  .upload-zone {
    border: 1px dashed rgba(201,169,110,0.4);
    padding: 3rem;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.25s, background 0.25s;
    position: relative;
    overflow: hidden;
  }
  .upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--gold);
    background: rgba(201,169,110,0.04);
  }
  .upload-zone input[type="file"] {
    position: absolute; inset: 0;
    opacity: 0; cursor: pointer; width: 100%; height: 100%;
  }
  .upload-icon {
    width: 56px; height: 56px;
    border: 1px solid var(--border);
    margin: 0 auto 1.25rem;
    display: flex; align-items: center; justify-content: center;
    color: var(--gold);
  }
  .upload-icon svg { width: 24px; height: 24px; }
  .upload-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 400; margin-bottom: 0.5rem; }
  .upload-sub { font-size: 0.8rem; color: var(--muted); letter-spacing: 0.05em; }

  /* Preview */
  #preview-container {
    display: none;
    margin-top: 1.5rem;
  }
  .photos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }
  .photo-thumb {
    position: relative;
    border: 1px solid var(--border);
    overflow: hidden;
    aspect-ratio: 1;
  }
  .photo-thumb img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .remove-btn {
    position: absolute; top: 0.4rem; right: 0.4rem;
    background: rgba(26,26,26,0.85);
    border: 1px solid var(--border);
    color: #fff;
    cursor: pointer;
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .remove-btn:hover { color: var(--gold); }

  /* Options */
  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin: 1.75rem 0;
  }
  @media (max-width: 600px) { .options-grid { grid-template-columns: 1fr; } }

  .field-group label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.6rem;
  }
  .field-group select,
  .field-group input[type="text"],
  .field-group textarea {
    width: 100%;
    background: rgba(26,26,26,0.6);
    border: 1px solid var(--border);
    color: var(--warm-white);
    font-family: var(--font-body);
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    outline: none;
    appearance: none;
    transition: border-color 0.2s;
  }
  .field-group select:focus,
  .field-group input[type="text"]:focus,
  .field-group textarea:focus { border-color: var(--gold); }
  .field-group select option { background: var(--charcoal); }
  .field-group textarea { resize: vertical; min-height: 80px; line-height: 1.6; }

  .generate-btn {
    width: 100%;
    padding: 1.1rem;
    background: var(--gold);
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.25s, transform 0.2s;
    display: flex; align-items: center; justify-content: center; gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .generate-btn:hover:not(:disabled) { background: var(--gold-light); transform: translateY(-1px); }
  .generate-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }

  /* Result */
  #result-section { display: none; margin-top: 2.5rem; }
  .result-label {
    font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.75rem;
  }
  .result-label::before { content: ''; width: 24px; height: 1px; background: var(--gold); }

  .compare-wrap {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
    border: 1px solid var(--border);
  }
  @media (max-width: 680px) { .compare-wrap { grid-template-columns: 1fr; } }

  .compare-panel { position: relative; }
  .compare-tag {
    position: absolute; top: 0.75rem; left: 0.75rem;
    background: rgba(26,26,26,0.85);
    border: 1px solid var(--border);
    font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.35rem 0.75rem; color: var(--muted);
  }
  .compare-panel img { width: 100%; max-height: 380px; object-fit: cover; display: block; }

  /* Render placeholder (animated) */
  .render-placeholder {
    aspect-ratio: 4/3;
    background: var(--charcoal);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 1rem;
  }
  .render-spinner {
    width: 40px; height: 40px;
    border: 1px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .render-status { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.08em; }

  #render-img { display: none; width: 100%; max-height: 380px; object-fit: cover; }

  .result-actions {
    display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;
  }
  .result-note {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--muted);
    padding: 1rem;
    border-left: 2px solid var(--gold);
    background: rgba(46,134,171,0.05);
    line-height: 1.7;
  }

  /* Loading overlay */
  #loading-overlay {
    display: none;
    position: fixed; inset: 0; z-index: 200;
    background: rgba(26,26,26,0.9);
    backdrop-filter: blur(8px);
    flex-direction: column;
    align-items: center; justify-content: center;
    gap: 1.5rem;
  }
  #loading-overlay.active { display: flex; }
  .loading-ring {
    width: 64px; height: 64px;
    border: 1px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  .loading-text {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--warm-white);
    letter-spacing: 0.05em;
  }
  .loading-sub {
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-align: center;
    max-width: 320px;
    line-height: 1.7;
  }
  .loading-steps { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.5rem; }
  .loading-step {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    opacity: 0;
    transition: opacity 0.4s, color 0.4s;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .loading-step.active { opacity: 1; color: var(--gold); }
  .loading-step.done { opacity: 0.5; color: var(--muted); }
  .step-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor; flex-shrink: 0;
  }

  /* Error */
  .error-msg {
    display: none;
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(226,75,74,0.4);
    background: rgba(226,75,74,0.05);
    color: #F09595;
    font-size: 0.85rem;
    line-height: 1.7;
  }
  .error-msg.show { display: block; }

  /* ─── API KEY SETUP ─── */
  .api-setup {
    background: rgba(46,134,171,0.07);
    border: 1px solid var(--border);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .api-setup-title {
    font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.75rem;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .api-setup p { font-size: 0.82rem; color: var(--muted); margin-bottom: 0.75rem; }
  .api-input-row { display: flex; gap: 0.75rem; }
  .api-input-row input {
    flex: 1;
    background: rgba(26,26,26,0.6);
    border: 1px solid var(--border);
    color: var(--warm-white);
    font-family: var(--font-body);
    font-size: 0.875rem;
    padding: 0.65rem 1rem;
    outline: none;
  }
  .api-input-row input:focus { border-color: var(--gold); }
  .api-save-btn {
    padding: 0.65rem 1.5rem;
    background: var(--gold);
    color: var(--charcoal);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .api-save-btn:hover { background: var(--gold-light); }
  .api-status {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
  }
  .api-status.ok { color: #5DCAA5; }
  .api-status.err { color: #F09595; }

  /* ─── PRODUCTS TEASER ─── */
  .products-section { padding: 6rem 3rem; }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    margin-top: 3.5rem;
    border: 1px solid var(--border);
  }
  .product-card {
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--border);
    transition: background 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .product-card:last-child { border-right: none; }
  .product-card:hover { background: rgba(46,134,171,0.06); }
  .product-cat {
    font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.75rem;
  }
  .product-name {
    font-family: var(--font-display);
    font-size: 1.1rem; font-weight: 400;
    margin-bottom: 0.5rem;
  }
  .product-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.7; }

  /* ─── FOOTER ─── */
  footer {
    padding: 0.5rem 3rem;
    background: #000000;
    border-top: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }
  footer p { font-size: 0.78rem; color: var(--muted); }
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.1rem; font-weight: 400; color: var(--gold);
  }

  /* Responsive */
  /* ── RESPONSIVE TABLET (768px) ─────────────────── */
  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-logo { font-size: 0.85rem; }
    .hero, .section, .tool-section, .products-section { padding-left: 1.5rem; padding-right: 1.5rem; }
    .hero { padding-top: 7rem; padding-bottom: 4rem; min-height: auto; }
    .hero-content { max-width: 100%; }
    footer { padding: 2rem 1.5rem; }
    .steps-grid { grid-template-columns: 1fr; border: none; gap: 1rem; }
    .step { border-right: none; border: 1px solid var(--border); }
    .options-grid { grid-template-columns: 1fr; }
    .prod-grid { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); max-height: 300px; }
    .photos-grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); }
    .tool-wrapper { padding: 0; }
  }

  /* ── RESPONSIVE MOBILE (480px) ─────────────────── */
  @media (max-width: 480px) {
    nav { padding: 0.85rem 1rem; }
    .nav-logo { font-size: 0.75rem; letter-spacing: 0.12em; }
    .nav-logo span { display: none; }
    .hero { padding: 6rem 1rem 3rem; }
    .hero-title { font-size: clamp(2rem, 8vw, 2.8rem); }
    .hero-sub { font-size: 0.9rem; }
    .hero-ctas { flex-direction: column; gap: 0.75rem; }
    .hero-ctas a { width: 100%; text-align: center; justify-content: center; }
    .section, .tool-section, .products-section { padding-left: 1rem; padding-right: 1rem; }
    .section-title { font-size: clamp(1.6rem, 6vw, 2.2rem); }
    .section-sub { font-size: 0.85rem; }
    .steps-grid { margin-top: 2rem; }
    .step { padding: 1.5rem 1rem; }
    .options-grid { grid-template-columns: 1fr; gap: 1rem; }
    .field-group input, .field-group select { font-size: 16px; /* evita zoom en iOS */ }
    .prod-cats { gap: 0.4rem; }
    .prod-cat-btn { padding: 0.4rem 0.75rem; font-size: 0.68rem; }
    .prod-grid { grid-template-columns: repeat(auto-fill, minmax(85px, 1fr)); max-height: 260px; }
    .prod-card-name { font-size: 0.62rem; padding: 0.3rem; }
    .photos-grid { grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
    .photo-thumb { aspect-ratio: 1; }
    .upload-zone { padding: 2rem 1rem; }
    .upload-title { font-size: 0.85rem; }
    .upload-sub { font-size: 0.72rem; }
    .generate-btn { font-size: 0.8rem; padding: 1rem; }
    .wa-float { padding: 0.9rem; border-radius: 50%; }
    .wa-float span { display: none; }
    .products-grid { grid-template-columns: 1fr 1fr; }
    footer .footer-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .form-wrapper { padding: 1.25rem 1rem; }
    .field-group { margin-bottom: 0.75rem; }
    .prod-selected-info img { width: 48px; height: 48px; }
  }

  /* ─── WHATSAPP FLOAT ─── */
  .wa-float {
    position: fixed; bottom: 2rem; right: 2rem; z-index: 150;
    display: flex; align-items: center; gap: 0.65rem;
    background: #25D366;
    color: #fff;
    padding: 0.8rem 1.4rem 0.8rem 1rem;
    border-radius: 50px;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(37,211,102,0.35);
    transition: transform 0.2s, box-shadow 0.2s;
    letter-spacing: 0.04em;
  }
  .wa-float:hover { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(37,211,102,0.45); }
  .wa-float svg { flex-shrink: 0; }
  

  .form-wrapper {
    margin-top: 2rem;
    border: 1px solid var(--border);
    padding: 1.75rem;
    background: rgba(46,134,171,0.04);
  }

  /* ─── PRODUCT SELECTOR ─── */
  .prod-selector-wrap { margin-top: 1.5rem; }
  .prod-cats {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem;
  }
  .prod-cat-btn {
    padding: 0.45rem 1rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-body);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .prod-cat-btn:hover { border-color: var(--gold); color: var(--gold); }
